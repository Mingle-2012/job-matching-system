APP_NAME=hybrid-rag-job-matching
APP_HOST=0.0.0.0
APP_PORT=8000

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=app
MYSQL_PASSWORD=app_password
MYSQL_DATABASE=job_matching

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

QDRANT_HOST=qdrant
QDRANT_PORT=6333
CANDIDATE_COLLECTION=candidate_chunks
JOB_COLLECTION=job_chunks
VECTOR_SIZE=3072

REDIS_URL=redis://redis:6379/0

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_TIMEOUT_SECONDS=60

GRAPH_TOP_K=200
VECTOR_TOP_K=200
RRF_K=60
RERANK_TOP_N=30
LLM_RERANK_TOP_N=20
LLM_RERANK_WEIGHT=0.35
PREFILTER_LIMIT=5000

GT_RULE_ENABLED=true
GT_RULE_FILE=/dataset/gt_learned_rules.json
GT_NAME_BOOST_WEIGHT=0.0
DOMAIN_TAXONOMY_FILE=

HARD_FILTER_YEAR_TOLERANCE=0.5
ROLE_MISMATCH_PENALTY=-0.3
HYBRID_WEIGHT_SKILL=0.4
HYBRID_WEIGHT_VECTOR=0.3
HYBRID_WEIGHT_ROLE=0.2
HYBRID_WEIGHT_EXPERIENCE=0.1
HYBRID_WEIGHT_DOMAIN=0.0
